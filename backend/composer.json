{
	"name": "edl-carepa/backend",
	"description": "EDL-CAREPA Evaluacion del Desempeno Laboral - Backend API",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^6.11",
        "phpmailer/phpmailer": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "block-insecure": false
        }
    }
}
